{
    "name": "iobroker.vis-2-widgets-automatic-feeder",
    "version": "0.2.1",
    "description": "ioBroker vis-2 widgets for the Automatic Feeder adapter (scheduled pond/fish feeder)",
    "author": "ssbingo <silvio.sternitzke@googlemail.com>",
    "contributors": [
        "ssbingo <silvio.sternitzke@googlemail.com>"
    ],
    "homepage": "https://github.com/ssbingo/ioBroker.vis-2-widgets-automatic-feeder",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/ssbingo/ioBroker.vis-2-widgets-automatic-feeder"
    },
    "keywords": [
        "ioBroker",
        "vis-2",
        "widgets",
        "visualization",
        "automatic-feeder",
        "pond",
        "aquarium",
        "koi"
    ],
    "devDependencies": {
        "@alcalzone/release-script": "^5.2.1",
        "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
        "@alcalzone/release-script-plugin-license": "^5.2.0",
        "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
        "@iobroker/build-tools": "^3.0.1",
        "@iobroker/eslint-config": "^2.3.4",
        "@iobroker/testing": "^5.2.2",
        "@iobroker/types-vis-2": "^2.14.4"
    },
    "main": "widgets/vis-2-widgets-automatic-feeder/customWidgets.js",
    "files": [
        "admin/",
        "widgets/",
        "img/",
        "doc/",
        "io-package.json",
        "LICENSE",
        "src-widgets-ts/src/i18n/"
    ],
    "scripts": {
        "prepublishOnly": "node tasks",
        "lint": "cd src-widgets-ts && eslint -c eslint.config.mjs",
        "build": "node tasks --typescript",
        "build-ts": "node tasks --typescript",
        "release": "release-script",
        "release-patch": "release-script patch --yes",
        "release-minor": "release-script minor --yes",
        "release-major": "release-script major --yes",
        "test": "npm run test:package",
        "test:package": "mocha test/package --exit",
        "update-packages": "npx -y npm-check-updates --upgrade && cd src-widgets-ts && npx -y npm-check-updates --upgrade",
        "npm": "npm i -f && cd src-widgets-ts && npm i -f"
    },
    "bugs": {
        "url": "https://github.com/ssbingo/ioBroker.vis-2-widgets-automatic-feeder/issues"
    },
    "readmeFilename": "README.md"
}
